// NOTE: This is a simplified Android-like editor UI built with React Native style logic // In a real Android app, you'd use Java/Kotlin + Android SDK + NDK (clang) to compile C.

import React, { useState } from "react"; import { View, TextInput, Button, Text, ScrollView } from "react-native";

export default function CEditorApp() { const [code, setCode] = useState(#include <stdio.h>\n\nint main() {\n    printf("Hello, World!\\n");\n    return 0;\n}); const [output, setOutput] = useState("");

// Fake compiler (real one would call native NDK/clang) const compileCode = () => { if (code.includes("printf")) { setOutput("Hello, World! (simulated output)"); } else { setOutput("Compilation error (simulated)"); } };

return ( <View style={{ flex: 1, padding: 20 }}> <Text style={{ fontSize: 20, fontWeight: "bold" }}>C Editor</Text>

<TextInput
    multiline
    value={code}
    onChangeText={setCode}
    style={{
      borderWidth: 1,
      borderColor: "#ccc",
      padding: 10,
      height: 200,
      marginVertical: 10,
      fontFamily: "monospace",
    }}
  />

  <Button title="Compile & Run" onPress={compileCode} />

  <ScrollView style={{ marginTop: 20 }}>
    <Text style={{ fontWeight: "bold" }}>Output:</Text>
    <Text>{output}</Text>
  </ScrollView>
</View>

); }

